{
  "name": "backend-utp-api",
  "version": "1.0.0",
  "description": "API GraphQL UTP - Simulación de pagos de matrículas con PM2 cluster",
  "main": "src/index.js",
  "scripts": {
    "seed": "node scripts/seed.js",
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "pm2:start": "npm run seed && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs utp-matriculas-api",
    "pm2:monit": "pm2 monit",
    "lint": "eslint . && node -e \"console.log('✓ ESLint: sin errores ni advertencias')\"",
    "lint:fix": "eslint . --fix && node -e \"console.log('✓ ESLint: código corregido / sin errores')\"",
    "lint:demo": "eslint eslint-ejemplos/ejemplos.js --no-ignore",
    "validate": "node scripts/validate-syntax.js",
    "build": "node scripts/build.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "ci": "npm run lint && npm run validate && npm run test:unit && npm run build"
  },
  "keywords": [
    "graphql",
    "utp",
    "matriculas",
    "pm2",
    "pino"
  ],
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@faker-js/faker": "^9.6.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "graphql": "^16.10.0",
    "mongodb": "^6.21.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "pm2": "^5.4.3"
  }
}
